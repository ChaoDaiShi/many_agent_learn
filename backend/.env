# ============================================
# AI智学助手 - 环境变量配置文件
# 请根据实际部署环境修改以下配置
# ============================================

# ----------------------------
# MySQL数据库配置
# ----------------------------
MYSQL_HOST=localhost           # 数据库主机地址
MYSQL_PORT=3306               # 数据库端口
MYSQL_USER=root               # 数据库用户名
MYSQL_PASSWORD=password       # 数据库密码（生产环境请使用强密码）
MYSQL_DATABASE=ai_edu_db      # 数据库名称

# ----------------------------
# 讯飞星火大模型API配置
# 请在讯飞开放平台申请后填写以下信息
# ----------------------------
SPARK_APP_ID=your_app_id            # 应用ID
SPARK_API_KEY=your_api_key          # API密钥
SPARK_API_SECRET=your_api_secret    # API密钥密钥
SPARK_API_URL=wss://spark-api.xf-yun.com/v3.1/chat  # API服务地址

# ----------------------------
# 向量数据库与文件存储配置
# ----------------------------
CHROMA_PATH=./chroma_db        # Chroma向量数据库存储路径
UPLOAD_FOLDER=./uploads        # 文件上传目录

# ----------------------------
# JWT认证配置
# ----------------------------
JWT_SECRET_KEY=your_jwt_secret_key  # JWT密钥（生产环境请使用安全的随机字符串）
JWT_ALGORITHM=HS256                 # JWT算法